# Database
DATABASE_URL=postgresql://labrats_user:labrats_password@localhost:5432/labrats_db
ASYNC_DATABASE_URL=postgresql+asyncpg://labrats_user:labrats_password@localhost:5432/labrats_db

# JWT Secret
SECRET_KEY=your-secret-key-change-this-in-production-make-it-long-and-random-123456789
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis for caching and rate limiting
REDIS_URL=redis://localhost:6379/0

# Security
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
